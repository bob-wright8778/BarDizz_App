<?xml version="1.0" encoding="utf-8"?>
<!-- Modify this file to customize your launch splash screen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Design handoff page background: the app is dark-only, so this
         doesn't follow the system theme's background. -->
    <item android:drawable="@color/page_background" />
    <item>
        <bitmap android:gravity="center" android:src="@mipmap/launch_image" />
    </item>
</layer-list>
